# ──────────────────────────────────────────────────────────────
# FinanceAI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# ── Database (MongoDB Atlas — mongodb.com/atlas) ──────────────
# Free M0 cluster is enough for development and early users
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/financeai?retryWrites=true&w=majority"

# ── Auth.js ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth Providers ────────────────────────────────────────────
# Google — console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub — github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── AI (OpenRouter — openrouter.ai) ───────────────────────────
# Free tier available. Mistral 7B is fast and cheap (~$0.001/call)
OPENROUTER_API_KEY=""
# Model for import categorization (fast, cheap — Mistral 7B or similar)
OPENROUTER_MODEL="mistralai/mistral-7b-instruct"
# Model for insights generation (can be smarter, e.g. claude-3-haiku or mistral-small)
OPENROUTER_INSIGHTS_MODEL="mistralai/mistral-7b-instruct"

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CURRENCY="INR"
